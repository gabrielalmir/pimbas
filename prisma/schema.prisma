generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String?              @map("password_hash")
  googleSub           String?              @unique @map("google_sub")
  name                String
  avatarUrl           String?              @map("avatar_url")
  tokenVersion        Int                  @default(0) @map("token_version")
  profile             PlayerProfile?
  memberships         GroupMember[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now()) @map("created_at")

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model PlayerProfile {
  id               String        @id @default(cuid())
  userId           String?       @unique @map("user_id")
  displayName      String        @map("display_name")
  initials         String
  avatarUrl        String?       @map("avatar_url")
  avatarPresetId   String?       @map("avatar_preset_id")
  shirtNumber      Int           @map("shirt_number")
  favoritePosition String        @map("favorite_position")
  style            String
  nationality      String
  bio              String
  isAnonymous      Boolean       @default(false) @map("is_anonymous")
  user             User?         @relation(fields: [userId], references: [id])
  memberships      GroupMember[]

  @@map("player_profiles")
}

model Group {
  id                   String        @id @default(cuid())
  name                 String
  description          String
  logoUrl              String?       @map("logo_url")
  logoPresetId         String?       @map("logo_preset_id")
  inviteCode           String        @unique @map("invite_code")
  defaultMatchSettings Json          @map("default_match_settings")
  members              GroupMember[]
  matches              Match[]
  tournaments          Tournament[]

  @@map("groups")
}

model GroupMember {
  id       String        @id @default(cuid())
  groupId  String        @map("group_id")
  playerId String        @map("player_id")
  userId   String?       @map("user_id")
  role     String
  group    Group         @relation(fields: [groupId], references: [id])
  player   PlayerProfile @relation(fields: [playerId], references: [id])
  user     User?         @relation(fields: [userId], references: [id])

  @@unique([groupId, playerId])
  @@index([groupId])
  @@map("group_members")
}

model Match {
  id           String       @id @default(cuid())
  groupId      String       @map("group_id")
  tournamentId String?      @map("tournament_id")
  kind         String
  status       String
  settings     Json
  pairs        MatchPair[]
  goals        Goal[]
  startedAt    DateTime     @map("started_at")
  finishedAt   DateTime?    @map("finished_at")
  winnerPairId String?      @map("winner_pair_id")
  group        Group        @relation(fields: [groupId], references: [id])
  tournament   Tournament?  @relation(fields: [tournamentId], references: [id])

  @@index([groupId, status])
  @@map("matches")
}

model MatchPair {
  id      String       @id @default(cuid())
  matchId String       @map("match_id")
  slot    String
  name    String
  players PairPlayer[]
  match   Match        @relation(fields: [matchId], references: [id])

  @@map("match_pairs")
}

model PairPlayer {
  id          String    @id @default(cuid())
  matchPairId String    @map("match_pair_id")
  playerId    String    @map("player_id")
  position    String
  matchPair   MatchPair @relation(fields: [matchPairId], references: [id])

  @@map("pair_players")
}

model Goal {
  id          String   @id @default(cuid())
  matchId     String   @map("match_id")
  matchPairId String   @map("match_pair_id")
  playerId    String   @map("player_id")
  position    String
  ownGoal     Boolean  @default(false) @map("own_goal")
  scoredAt    DateTime @default(now()) @map("scored_at")
  match       Match    @relation(fields: [matchId], references: [id])

  @@index([matchId])
  @@map("goals")
}

model Tournament {
  id                String  @id @default(cuid())
  groupId           String  @map("group_id")
  name              String
  status            String
  settings          Json
  pairs             Json
  matchups          Json
  thirdPlaceMatchup Json?   @map("third_place_matchup")
  championPairId    String? @map("champion_pair_id")
  group             Group   @relation(fields: [groupId], references: [id])
  matches           Match[]

  @@index([groupId])
  @@map("tournaments")
}
